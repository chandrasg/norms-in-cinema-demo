---
import "../styles/globals.css";
import BrandHeader from "../components/BrandHeader.astro";
import PartnerFooter from "../components/PartnerFooter.astro";
import KioskMode from "../components/KioskMode.astro";

interface Props {
  title?: string;
  description?: string;
  station?: string;
}
const {
  title = "MAPGEN: Cinema's Mirror — Shame, Pride and Prejudice",
  description = "A cross-cultural reading of shame and pride in Bollywood and Hollywood. By Penn, USC Annenberg Norman Lear Center, and the World Bank Group. Built on Rai et al. (NAACL 2025).",
  station,
} = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const SITE_URL = "https://chandrasg.github.io/norms-in-cinema-demo";
const ogImage = SITE_URL + "/icon-512.png";
const canonical = SITE_URL + (station ? `/${station}` : "/");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Favicons -->
    <link rel="icon" type="image/png" href={base + "/icon-512.png"} />
    <link rel="apple-touch-icon" href={base + "/icon-512.png"} />
    <meta name="theme-color" content="#0e1530" />

    <!-- Open Graph (LinkedIn, Slack, Discord, etc.) -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="MAPGEN: Cinema's Mirror" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="MAPGEN — Mapping Gender Norms in Entertainment Media" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Structured data — Dataset (helps academic citation discovery) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Dataset",
      "name": "MAPGEN: Cinema's Mirror — Cross-Cultural Norms in Bollywood and Hollywood",
      "description": "Interactive analysis of 12,387 shame and pride dialogue excerpts across ~5,400 Bollywood and Hollywood films, with theme clustering and gendered-target labeling.",
      "url": canonical,
      "license": "https://creativecommons.org/licenses/by-sa/4.0/",
      "creator": [
        { "@type": "Organization", "name": "University of Pennsylvania" },
        { "@type": "Organization", "name": "USC Annenberg Norman Lear Center" },
        { "@type": "Organization", "name": "World Bank Group" }
      ],
      "isBasedOn": "https://aclanthology.org/2025.naacl-long.568"
    })} />

    <link rel="preconnect" href="https://image.tmdb.org" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&display=swap"
    />
  </head>
  <body class="grain min-h-screen">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:bg-gold-400 focus:text-ink-950 focus:px-4 focus:py-2 focus:rounded-lg">
      Skip to main content
    </a>
    <BrandHeader station={station} />
    <main id="main-content" tabindex="-1">
      <slot />
    </main>
    <PartnerFooter />
    <KioskMode />
  </body>
</html>
