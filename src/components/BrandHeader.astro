---
interface Props {
  station?: string;  // "mirror" | "atlas" | "lens" | undefined for index
}
const { station } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<header class="border-b border-white/5">
  <div class="container-kiosk flex items-center justify-between py-5">
    <a href={base + "/"} class="flex items-center gap-3 group">
      <img
        src={base + "/logos/file_00000000420c61f6838119d65d059d02 (1).png"}
        alt=""
        class="h-9 w-9 rounded-md ring-1 ring-white/10"
      />
      <div>
        <p class="text-xs uppercase tracking-[0.25em] text-gold-400 transition group-hover:text-gold-300">
          MAPGEN
        </p>
        <p class="text-sm text-white/70 -mt-0.5 font-display italic">Cinema's Mirror</p>
      </div>
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      <a
        href={base + "/mirror"}
        class={`rounded-full px-4 py-2 text-sm transition ${station === "mirror" ? "bg-white/10 text-white" : "text-white/60 hover:text-white"}`}
      >The Mirror</a>
      <a
        href={base + "/atlas"}
        class={`rounded-full px-4 py-2 text-sm transition ${station === "atlas" ? "bg-white/10 text-white" : "text-white/60 hover:text-white"}`}
      >The Atlas</a>
      <a
        href={base + "/lens"}
        class={`rounded-full px-4 py-2 text-sm transition ${station === "lens" ? "bg-white/10 text-white" : "text-white/60 hover:text-white"}`}
      >The Lens</a>
    </nav>
  </div>
</header>
