---
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<footer class="mt-32 border-t border-white/10 bg-ink-950/60 py-10 backdrop-blur">
  <div class="container-kiosk">
    <div class="mb-6 flex items-center justify-between gap-6">
      <p class="text-xs uppercase tracking-[0.2em] text-white/40">A research collaboration of</p>
      <p class="text-xs uppercase tracking-[0.2em] text-gold-400">Cannes 2026</p>
    </div>

    <div class="grid grid-cols-2 items-center gap-6 md:grid-cols-3">
      <a href="https://www.med.upenn.edu/guntukulab/"
         target="_blank" rel="noopener"
         class="rounded-lg bg-white p-5 block hover:ring-2 hover:ring-gold-400/40 transition"
         title="Guntuku Lab at Penn">
        <img
          src={base + "/logos/UniversityofPennsylvania_FullLogo_RGB.png"}
          alt="University of Pennsylvania — Guntuku Lab"
          class="h-10 w-auto mx-auto"
          loading="lazy"
        />
      </a>
      <a href="https://www.worldbank.org/en/research/dime"
         target="_blank" rel="noopener"
         class="rounded-lg bg-white p-5 block hover:ring-2 hover:ring-gold-400/40 transition"
         title="World Bank DIME (Development Impact Evaluation)">
        <img
          src={base + "/logos/WBG_Horizontal-RGB.jpg"}
          alt="World Bank Group — DIME"
          class="h-10 w-auto mx-auto"
          loading="lazy"
        />
      </a>
      <a href="https://www.mediaimpactproject.org/"
         target="_blank" rel="noopener"
         class="rounded-lg bg-white p-5 col-span-2 md:col-span-1 block hover:ring-2 hover:ring-gold-400/40 transition"
         title="USC Annenberg Norman Lear Center — Media Impact Project">
        <img
          src={base + "/logos/ascj_normanlearcenter_media_impact_project_cardblack_informal_horiz.webp"}
          alt="USC Annenberg Norman Lear Center — Media Impact Project"
          class="h-10 w-auto mx-auto"
          loading="lazy"
        />
      </a>
    </div>

    <!-- Resource links -->
    <div class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-3 text-xs">
      <a href={base + "/about"}
         class="inline-flex items-center gap-1.5 text-white/70 hover:text-gold-400 transition">
        <span>⚙</span>
        Method &amp; citations
      </a>
      <a href={base + "/paper.pdf"} target="_blank" rel="noopener"
         class="inline-flex items-center gap-1.5 text-white/70 hover:text-gold-400 transition">
        <span>📄</span>
        Read the paper (Rai et al., NAACL 2025)
      </a>
      <a href="https://github.com/Khushangz/Cross-Cultural-Social-Norms-Dataset" target="_blank" rel="noopener"
         class="inline-flex items-center gap-1.5 text-white/70 hover:text-gold-400 transition">
        <span>⌥</span>
        Source dataset on GitHub
      </a>
      <a href="https://github.com/chandrasg/norms-in-cinema-demo" target="_blank" rel="noopener"
         class="inline-flex items-center gap-1.5 text-white/70 hover:text-gold-400 transition">
        <span>⌥</span>
        This site's source
      </a>
      <a href="#feedback"
         class="inline-flex items-center gap-1.5 text-white/70 hover:text-gold-400 transition">
        <span>✉</span>
        Share feedback
      </a>
    </div>

    <div class="mt-8 flex flex-col gap-2 text-xs text-white/40 md:flex-row md:items-center md:justify-between">
      <p>MAPGEN — Mapping Gender Norms in Entertainment Media.</p>
      <p>Examples shown illustrate broader patterns, not film-specific judgement.</p>
    </div>
  </div>
</footer>
