---
import Layout from "../layouts/Layout.astro";
import ThemeTugOfWar from "../components/Atlas/ThemeTugOfWar.tsx";
import FilmSearch from "../components/Atlas/FilmSearch.tsx";

const data = (await import("../../public/data/station2_atlas.json", { assert: { type: "json" } })).default;

const shameThemeCount = data.themes.filter((t: any) => t.emotion === "shame").length;
const prideThemeCount = data.themes.filter((t: any) => t.emotion === "pride").length;
---

<Layout title="The Atlas — MAPGEN: Cinema's Mirror" station="atlas">
  <section class="container-kiosk pt-16 pb-32">
    <p class="text-xs uppercase tracking-[0.3em] text-gold-400">Station 2</p>
    <h1 class="mt-3 font-display text-kiosk-xl text-white max-w-3xl">The Atlas.</h1>
    <p class="mt-4 max-w-2xl text-kiosk-md text-white/75 leading-snug">
      Two industries. {shameThemeCount} shame themes. {prideThemeCount} pride themes.
      The center line is balance. Every bar is a finding.
    </p>

    <!-- Takeaways at top -->
    <div class="mt-12 grid gap-4 md:grid-cols-3">
      <div class="panel p-6">
        <p class="text-xs uppercase tracking-[0.2em] text-bolly">Bollywood leans into</p>
        <p class="mt-2 font-display text-xl text-white leading-tight">
          Sexuality. Marriage. Family honor.
        </p>
        <p class="mt-3 text-sm text-white/65">
          The community's gaze polices intimate life. Shame is delivered
          publicly and inherited collectively.
        </p>
      </div>
      <div class="panel p-6">
        <p class="text-xs uppercase tracking-[0.2em] text-holly">Hollywood leans into</p>
        <p class="mt-2 font-display text-xl text-white leading-tight">
          Poverty. Self-image. Negligence.
        </p>
        <p class="mt-3 text-sm text-white/65">
          Individuals fail to live up to themselves. Shame is self-administered
          behind closed doors.
        </p>
      </div>
      <div class="panel p-6">
        <p class="text-xs uppercase tracking-[0.2em] text-gold-400">Where they converge</p>
        <p class="mt-2 font-display text-xl text-white leading-tight">
          Women's bodies.
        </p>
        <p class="mt-3 text-sm text-white/65">
          Sexual Harassment, Modesty, Promiscuity are prominent in Bollywood
          and persist in Hollywood. Different vocabulary. Same line.
        </p>
      </div>
    </div>

    <!-- SHAME tug-of-war -->
    <div class="mt-20">
      <h2 class="font-display text-3xl text-white">What evokes shame?</h2>
      <p class="mt-2 text-sm text-white/60 max-w-xl">
        Each bar's length is the cultural Δ — how much more or less prominent
        that theme is in one industry vs. the other. Click any theme to read
        examples from the films.
      </p>
      <div class="mt-8">
        <ThemeTugOfWar client:load themes={data.themes} emotion="shame" />
      </div>
    </div>

    <!-- PRIDE tug-of-war -->
    <div class="mt-24">
      <h2 class="font-display text-3xl text-white">What evokes pride?</h2>
      <p class="mt-2 text-sm text-white/60 max-w-xl">
        Bollywood pride is collective and male — a son's accomplishments,
        nation, family honor. Hollywood pride is individual — identity,
        ambition, financial success.
      </p>
      <div class="mt-8">
        <ThemeTugOfWar client:load themes={data.themes} emotion="pride" />
      </div>
    </div>

    <!-- Film search — fixed sort, sensible defaults -->
    <div class="mt-24">
      <FilmSearch client:load films={data.films_index} />
    </div>
  </section>
</Layout>
