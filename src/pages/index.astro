---
import Layout from "../layouts/Layout.astro";
import Feedback from "../components/Feedback.tsx";

const meta = (await import("../../public/data/meta.json", { assert: { type: "json" } })).default;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const feedbackEndpoint = import.meta.env.PUBLIC_FEEDBACK_ENDPOINT || "";
---

<Layout>
  <section class="container-kiosk pt-10 md:pt-24 pb-24 md:pb-32">
    <p class="mb-4 text-xs uppercase tracking-[0.3em] text-gold-400">
      Penn · World Bank · Norman Lear Center
    </p>

    <h1 class="font-display text-kiosk-xl text-white max-w-4xl">
      <span class="text-white">Cinema's Mirror.</span>
      <span class="block italic text-white/70 mt-2">Shame, Pride and Prejudice.</span>
    </h1>

    <div class="accent-line my-10"></div>

    <p class="max-w-2xl text-kiosk-md text-white/80 leading-snug">
      <span class="text-white">{meta.corpus_size.toLocaleString()} lines of dialogue</span>
      from {meta.films_matched.toLocaleString()} films across Bollywood and Hollywood.
      Seeing them through the lens of two emotions —
      <span class="text-bolly">shame</span> and
      <span class="text-holly">pride</span> —
      makes visible the social expectations these films enforce.
    </p>

    <p class="mt-6 max-w-2xl text-base text-white/50">
      Cultures may differ, but gendered expectations are shared.
    </p>

    <!-- Persona quick-paths + resources -->
    <div class="mt-8">
      <p class="text-xs uppercase tracking-[0.25em] text-white/40 mb-3">Choose your path →</p>
      <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-4">
        <a href={base + "/studio#filmmakers"}
           class="rounded-xl bg-bolly/10 ring-1 ring-bolly/30 px-4 py-3 hover:bg-bolly/15 transition group">
          <p class="text-[11px] uppercase tracking-[0.18em] text-bolly">For filmmakers</p>
          <p class="mt-1 text-sm text-white/85">Norm Compass + writers' room checklist →</p>
        </a>
        <a href={base + "/studio#funders"}
           class="rounded-xl bg-gold-400/10 ring-1 ring-gold-400/30 px-4 py-3 hover:bg-gold-400/15 transition group">
          <p class="text-[11px] uppercase tracking-[0.18em] text-gold-400">For funders &amp; studios</p>
          <p class="mt-1 text-sm text-white/85">The Diverging Mirror + whitespace map →</p>
        </a>
        <a href={base + "/studio#programmers"}
           class="rounded-xl bg-holly/10 ring-1 ring-holly/30 px-4 py-3 hover:bg-holly/15 transition group">
          <p class="text-[11px] uppercase tracking-[0.18em] text-holly">For policy &amp; educators</p>
          <p class="mt-1 text-sm text-white/85">Convergence zone + discussion kit →</p>
        </a>
        <a href={base + "/about"}
           class="rounded-xl bg-white/5 ring-1 ring-white/15 px-4 py-3 hover:bg-white/10 transition group">
          <p class="text-[11px] uppercase tracking-[0.18em] text-white/60">For researchers</p>
          <p class="mt-1 text-sm text-white/85">Method, citations, limitations →</p>
        </a>
      </div>
      <div class="mt-4 flex flex-wrap items-center gap-2 text-xs">
        <a href={base + "/paper.pdf"} target="_blank" rel="noopener"
           class="inline-flex items-center gap-1.5 rounded-full bg-white/5 px-3 py-1.5 text-white/70 ring-1 ring-white/10 hover:bg-white/10 hover:text-white transition">
          <span class="text-gold-400">📄</span>
          Paper (Rai et al., NAACL 2025)
        </a>
        <a href="#feedback"
           class="inline-flex items-center gap-1.5 rounded-full bg-white/5 px-3 py-1.5 text-white/70 ring-1 ring-white/10 hover:bg-white/10 hover:text-white transition">
          <span class="text-gold-400">✉</span>
          Share input
        </a>
      </div>
    </div>

    <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      <a href={base + "/mirror"} class="panel block p-6 transition hover:ring-gold-400/40">
        <p class="text-xs uppercase tracking-[0.25em] text-gold-400">Station 1</p>
        <h2 class="mt-2 font-display text-2xl text-white">The Mirror</h2>
        <p class="mt-3 text-sm text-white/60 leading-relaxed">
          The headline numbers, the era trend that splits the two industries,
          and a guess game that lands the punchline.
        </p>
        <p class="mt-6 text-xs text-white/40">Begin →</p>
      </a>

      <a href={base + "/atlas"} class="panel block p-6 transition hover:ring-gold-400/40">
        <p class="text-xs uppercase tracking-[0.25em] text-gold-400">Station 2</p>
        <h2 class="mt-2 font-display text-2xl text-white">The Atlas</h2>
        <p class="mt-3 text-sm text-white/60 leading-relaxed">
          {meta.themes.shame + meta.themes.pride} themes mapped across both industries.
          Drill into any cluster and read the lines that built it.
        </p>
        <p class="mt-6 text-xs text-white/40">Explore →</p>
      </a>

      <a href={base + "/lens"} class="panel block p-6 transition hover:ring-gold-400/40">
        <p class="text-xs uppercase tracking-[0.25em] text-gold-400">Station 3</p>
        <h2 class="mt-2 font-display text-2xl text-white">The Lens</h2>
        <p class="mt-3 text-sm text-white/60 leading-relaxed">
          Pick a film. Or paste a scene of your own. Read it through both
          cultural lenses at once.
        </p>
        <p class="mt-6 text-xs text-white/40">Look →</p>
      </a>

      <a href={base + "/studio"} class="panel block p-6 transition hover:ring-gold-400/40 ring-1 ring-gold-400/20">
        <p class="text-xs uppercase tracking-[0.25em] text-gold-400">Station 4 · new</p>
        <h2 class="mt-2 font-display text-2xl text-white">The Studio</h2>
        <p class="mt-3 text-sm text-white/60 leading-relaxed">
          Stakeholder dossiers — for filmmakers, funders, and the people who
          program, study, and govern cinema. Three asks, one mirror.
        </p>
        <p class="mt-6 text-xs text-white/40">Open →</p>
      </a>
    </div>

    <!-- Feedback -->
    <div id="feedback" class="mt-24 scroll-mt-24">
      <Feedback client:load endpoint={feedbackEndpoint} />
    </div>
  </section>
</Layout>
