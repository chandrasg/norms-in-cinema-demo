---
import Layout from "../layouts/Layout.astro";
import GuessGame from "../components/Mirror/GuessGame.tsx";
import AsymmetryDots from "../components/Mirror/AsymmetryDots.tsx";
import EraTrend from "../components/Mirror/EraTrend.tsx";

const data = (await import("../../public/data/station1_mirror.json", { assert: { type: "json" } })).default;
const ratio = data.headline.shame_freq_ratio_bolly_to_holly.toFixed(1);
const bollyShame = (data.headline.shame_female_share_bolly * 100).toFixed(0);
const hollyShame = (data.headline.shame_female_share_holly * 100).toFixed(0);
const bollyPrideMale = (data.headline.pride_male_share_bolly * 100).toFixed(0);
const hollyPrideMale = (data.headline.pride_male_share_holly * 100).toFixed(0);
---

<Layout title="The Mirror — MAPGEN: Cinema's Mirror" station="mirror">
  <section class="container-kiosk pt-16 pb-32">
    <p class="text-xs uppercase tracking-[0.3em] text-gold-400">Station 1</p>
    <h1 class="mt-3 font-display text-kiosk-xl text-white max-w-3xl">The Mirror.</h1>
    <p class="mt-4 max-w-2xl text-kiosk-md text-white/75 leading-snug">
      Two cultures speak about shame and pride in different vocabularies.
      But the line between who is sanctioned and who is celebrated runs the
      same way in both.
    </p>

    <!-- Takeaway numbers up top — set the stakes immediately -->
    <div class="mt-12 grid gap-4 md:grid-cols-4">
      <div class="panel p-6">
        <p class="font-display text-5xl text-gold-400">{ratio}<span class="text-white/30 text-2xl">×</span></p>
        <p class="mt-3 text-sm text-white/70 leading-snug">
          more shame in Bollywood dialogue than Hollywood. Eastern cultures use shame
          openly — Western cultures avoid the word.
        </p>
      </div>
      <div class="panel p-6">
        <p class="font-display text-5xl text-bolly">{bollyShame}<span class="text-white/30 text-2xl">%</span></p>
        <p class="mt-3 text-sm text-white/70 leading-snug">
          of <span class="text-bolly">Bollywood</span> shame lands on women.
        </p>
      </div>
      <div class="panel p-6">
        <p class="font-display text-5xl text-holly">{hollyShame}<span class="text-white/30 text-2xl">%</span></p>
        <p class="mt-3 text-sm text-white/70 leading-snug">
          of <span class="text-holly">Hollywood</span> shame lands on women.
          <span class="text-white">Same line, different vocabulary.</span>
        </p>
      </div>
      <div class="panel p-6">
        <p class="font-display text-5xl text-white">{bollyPrideMale}<span class="text-white/30 text-2xl">%</span> <span class="text-white/40 text-xl">/</span> {hollyPrideMale}<span class="text-white/30 text-2xl">%</span></p>
        <p class="mt-3 text-sm text-white/70 leading-snug">
          of pride lands on men, in <span class="text-bolly">Bolly</span> /
          <span class="text-holly">Holly</span>. Cultural surfaces differ. The
          gendered substrate is shared.
        </p>
      </div>
    </div>

    <!-- ASYMMETRY DOTS — the visceral viz, surfaced first -->
    <div class="mt-20">
      <p class="text-xs uppercase tracking-[0.25em] text-white/50 mb-4">The shape of the corpus</p>
      <AsymmetryDots client:load asymmetry={data.asymmetry} />
    </div>

    <!-- ERA TREND — the new finding -->
    <div class="mt-20">
      <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
        <p class="text-xs uppercase tracking-[0.25em] text-white/50">Across decades</p>
        <a href={import.meta.env.BASE_URL.replace(/\/$/, "") + "/about"} class="text-xs text-white/40 hover:text-gold-400 transition">
          Method &amp; sample-size notes →
        </a>
      </div>
      <EraTrend client:load trend={data.era_trend} />
    </div>

    <!-- Linguistic tells -->
    <div class="mt-20">
      <p class="text-xs uppercase tracking-[0.25em] text-white/50 mb-4">Linguistic tells</p>
      <div class="grid gap-6 md:grid-cols-2">
        <div class="panel p-6">
          <p class="text-xs uppercase tracking-[0.25em] text-bolly">Bollywood shame, in two words</p>
          <h3 class="mt-2 font-display text-2xl text-white">"<em class="italic">You</em> should be ashamed."</h3>
          <p class="mt-3 text-sm text-white/65 leading-relaxed">
            Shame in Bollywood is <span class="text-white">other-directed</span>.
            Second-person pronouns and references to <em>family / sister / mother</em>
            dominate. The community delivers the verdict.
          </p>
        </div>
        <div class="panel p-6">
          <p class="text-xs uppercase tracking-[0.25em] text-holly">Hollywood shame, in two words</p>
          <h3 class="mt-2 font-display text-2xl text-white">"<em class="italic">I</em> should have known."</h3>
          <p class="mt-3 text-sm text-white/65 leading-relaxed">
            Shame in Hollywood is <span class="text-white">self-directed</span>.
            First-person pronouns and past-tense regret dominate. The character
            delivers the verdict on themselves.
          </p>
        </div>
      </div>
    </div>

    <!-- GUESS GAME — moved below; an interactive verification of what you just saw -->
    <div class="mt-20">
      <p class="text-xs uppercase tracking-[0.25em] text-white/50 mb-4">Now try it yourself — read it before the credits roll.</p>
      <GuessGame client:load rounds={data.guess_rounds} />
    </div>

    <p class="mt-24 max-w-2xl text-kiosk-md font-display italic text-white/70 leading-snug">
      The cultures argue about who deserves the sanction. They agree, mostly,
      on whose body it lands on.
    </p>
  </section>
</Layout>
