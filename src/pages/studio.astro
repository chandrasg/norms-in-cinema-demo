---
import Layout from "../layouts/Layout.astro";
import NormCompass from "../components/Studio/NormCompass.tsx";
import DivergingMirror from "../components/Studio/DivergingMirror.tsx";
import ConvergenceZone from "../components/Studio/ConvergenceZone.tsx";
import WhitespaceMap from "../components/Studio/WhitespaceMap.tsx";
import SubversionFiles from "../components/Studio/SubversionFiles.tsx";
import SlateDiagnostic from "../components/Studio/SlateDiagnostic.tsx";
import CountryPreview from "../components/Studio/CountryPreview.tsx";
import WritersChecklist from "../components/Studio/WritersChecklist.astro";
import FundersChecklist from "../components/Studio/FundersChecklist.astro";
import ProgrammersChecklist from "../components/Studio/ProgrammersChecklist.astro";
import DiscussionKit from "../components/Studio/DiscussionKit.astro";

const studio = (await import("../../public/data/station4_studio.json", { assert: { type: "json" } })).default;
const mirror = (await import("../../public/data/station1_mirror.json", { assert: { type: "json" } })).default;
const atlas = (await import("../../public/data/station2_atlas.json", { assert: { type: "json" } })).default;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout title="The Studio — MAPGEN: Cinema's Mirror" station="studio">
  <section class="container-kiosk pt-16 pb-32">
    <p class="text-xs uppercase tracking-[0.3em] text-gold-400">Station 4</p>
    <h1 class="mt-3 font-display text-kiosk-xl text-white max-w-3xl">The Studio.</h1>
    <p class="mt-4 max-w-2xl text-kiosk-md text-white/75 leading-snug">
      Three audiences. One mirror. Different asks. This is what MAPGEN unlocks
      for filmmakers, funders, and the people who program, study, and govern cinema.
    </p>

    <!-- Jump-to nav -->
    <div class="mt-10 flex flex-wrap gap-2 text-xs">
      <a href="#storytellers" class="rounded-full bg-bolly/10 ring-1 ring-bolly/30 px-3 py-2 text-bolly hover:bg-bolly/20 transition min-h-[40px] inline-flex items-center">
        ↓ For storytellers
      </a>
      <a href="#funders" class="rounded-full bg-gold-400/10 ring-1 ring-gold-400/30 px-3 py-2 text-gold-400 hover:bg-gold-400/20 transition min-h-[40px] inline-flex items-center">
        ↓ For funders &amp; studios
      </a>
      <a href="#programmers" class="rounded-full bg-holly/10 ring-1 ring-holly/30 px-3 py-2 text-holly hover:bg-holly/20 transition min-h-[40px] inline-flex items-center">
        ↓ For policy &amp; educators
      </a>
      <a href={base + "/about"} class="rounded-full bg-white/5 ring-1 ring-white/15 px-3 py-2 text-white/70 hover:bg-white/10 hover:text-white transition min-h-[40px] inline-flex items-center">
        Method &amp; citations →
      </a>
    </div>

    <!-- =========================================================== -->
    <!-- §1 — STORYTELLERS (writers, directors, content creators)     -->
    <!-- =========================================================== -->
    <div id="storytellers" class="mt-28 scroll-mt-24">
      <!-- Keep #filmmakers anchor working for old links -->
      <div id="filmmakers" class="absolute" aria-hidden="true"></div>
      <div class="border-l-2 border-bolly pl-6">
        <p class="text-xs uppercase tracking-[0.25em] text-bolly">Dossier 01 · For storytellers</p>
        <h2 class="mt-2 font-display text-4xl md:text-5xl text-white max-w-3xl leading-tight">
          Explore your dialogue for markers of shame and pride.
        </h2>
        <p class="mt-4 max-w-2xl text-base text-white/70 leading-relaxed">
          Every scene carries signals of the social norms it invokes — who is
          shamed, who is celebrated, and for what. MAPGEN surfaces
          <span class="text-white font-medium"> 12,387 such moments</span> across
          film dialogue, giving you a way to read your own scene against patterns
          the corpus has already mapped.
        </p>
        <p class="mt-3 max-w-2xl text-sm text-white/55 leading-relaxed">
          Built for screenwriters, directors, content creators, and anyone
          working in dialogue-driven storytelling — film, TV, web, or any
          longer-form format with characters and scenes.
        </p>
      </div>

      <!-- Try-it-now CTA — Lens is the universal tool but it lives a click
           away. Surface it at the top of this dossier so a writer who lands
           here can paste a scene in 10 seconds. -->
      <div class="mt-8 panel p-5 md:p-6 border border-gold-400/25 bg-gradient-to-r from-gold-400/[0.04] via-transparent to-transparent">
        <div class="flex flex-wrap items-center gap-4">
          <div class="flex-1 min-w-[260px]">
            <p class="text-[10px] uppercase tracking-[0.25em] text-gold-400">Try it now</p>
            <p class="mt-1 font-display text-lg text-white leading-tight">
              Paste a scene. See what each cultural lens registers.
            </p>
            <p class="mt-1 text-xs text-white/55 leading-relaxed">
              The fastest way to use this site as a writing tool — before you
              read another component.
            </p>
          </div>
          <a href={base + "/lens#paste-scene"}
             class="inline-flex items-center gap-2 rounded-full bg-gold-400 text-ink-950 px-5 py-2.5 text-sm font-medium hover:bg-gold-300 transition">
            Open The Lens →
          </a>
        </div>
      </div>

      <!-- How to read this — heading off the "is this telling me what to do?"
           reaction Erica + Ana Maria flagged in the monthly meeting. -->
      <div class="mt-8 max-w-2xl text-xs text-white/55 italic leading-relaxed border-l-2 border-bolly/30 pl-4">
        How to read this: the patterns below describe what the corpus contains —
        not what your scene should do. A theme appearing often means film
        dialogue has staged it many times in that pattern; it doesn't mean
        the pattern is endorsed, and it doesn't mean a scene that breaks the
        pattern is wrong. Use the data to consider how a draft might
        reproduce or subvert the dominant treatment.
      </div>

      <div class="mt-12">
        <NormCompass client:load archetypes={studio.compass} />
      </div>

      <div class="mt-10">
        <SubversionFiles client:load items={studio.subversions} />
      </div>

      <div class="mt-10">
        <WritersChecklist />
      </div>

      <div class="mt-10 panel p-6 md:p-8 border-l-2 border-bolly">
        <p class="text-xs uppercase tracking-[0.2em] text-bolly mb-2">What to do next</p>
        <p class="text-base text-white/80 leading-relaxed">
          Take a scene from your current project. Paste it into{" "}
          <a href={base + "/lens#paste-scene"} class="text-gold-400 hover:underline">The Lens</a> —
          we'll read it through both cultural lenses and surface what an Indian
          audience might register that an American one would miss, and vice versa.
        </p>
      </div>
    </div>

    <!-- =========================================================== -->
    <!-- §2 — FUNDERS                                                 -->
    <!-- =========================================================== -->
    <div id="funders" class="mt-32 scroll-mt-24">
      <div class="border-l-2 border-gold-400 pl-6">
        <p class="text-xs uppercase tracking-[0.25em] text-gold-400">Dossier 02 · Funders &amp; studios</p>
        <h2 class="mt-2 font-display text-4xl md:text-5xl text-white max-w-3xl leading-tight">
          What's the gender norm profile of your slate — and where's your audience moving?
        </h2>
        <p class="mt-4 max-w-2xl text-base text-white/70 leading-relaxed">
          Gender representation isn't a moral metric. It's a market signal. The
          two industries have started moving in opposite directions on the same
          measure since 2000 — and the audience has shown which way it's leaning.
        </p>
      </div>

      <!-- How to read this — descriptive, not prescriptive. Surfaced before
           the V2 panel so funders don't read the diverging chart as a
           judgement. -->
      <div class="mt-8 max-w-2xl text-xs text-white/55 italic leading-relaxed border-l-2 border-gold-400/30 pl-4">
        How to read this: the charts below describe how each industry has
        deployed shame and pride dialogue over time. The directions of those
        lines are what they are — the data isn't recommending one way over
        the other. Use it to ask which patterns your slate is amplifying and
        which it has space to complicate.
      </div>

      <!-- Theory of change — funders explicitly look for this. Names the
           causal chain inputs → outputs → outcomes → impact, in our terms. -->
      <div class="mt-10 panel p-6 md:p-8">
        <p class="text-xs uppercase tracking-[0.2em] text-gold-400">Theory of change</p>
        <h3 class="mt-2 font-display text-xl text-white max-w-3xl leading-snug">
          How a measurement layer for screen content becomes leverage for behaviour change.
        </h3>
        <div class="mt-5 grid gap-4 md:grid-cols-4 text-sm">
          <div class="rounded-lg bg-ink-950/40 ring-1 ring-white/5 p-4">
            <p class="text-[10px] uppercase tracking-[0.18em] text-gold-400/70 mb-2">Inputs</p>
            <p class="font-display text-base text-white leading-snug mb-2">Corpus + AI pipeline</p>
            <p class="text-xs text-white/60 leading-relaxed">
              ~12K dialogue moments today; ~250K target. NLP + LLM theme
              clustering, gendered-target labelling, peer-reviewed at NAACL.
            </p>
          </div>
          <div class="rounded-lg bg-ink-950/40 ring-1 ring-white/5 p-4">
            <p class="text-[10px] uppercase tracking-[0.18em] text-gold-400/70 mb-2">Outputs</p>
            <p class="font-display text-base text-white leading-snug mb-2">Diagnostics that funders + creators use</p>
            <p class="text-xs text-white/60 leading-relaxed">
              Slate audits, country profiles, pre-greenlight script review,
              theme-level reads. The dashboards on this site are V1.
            </p>
          </div>
          <div class="rounded-lg bg-ink-950/40 ring-1 ring-white/5 p-4">
            <p class="text-[10px] uppercase tracking-[0.18em] text-gold-400/70 mb-2">Outcomes</p>
            <p class="font-display text-base text-white leading-snug mb-2">Better-targeted SBCC + commissioning decisions</p>
            <p class="text-xs text-white/60 leading-relaxed">
              Funders + studios make norm-aware investments. Productions
              calibrate culturally. Programmers curate with intent. Each
              decision is now informed, not intuited.
            </p>
          </div>
          <div class="rounded-lg bg-ink-950/40 ring-1 ring-white/5 p-4">
            <p class="text-[10px] uppercase tracking-[0.18em] text-gold-400/70 mb-2">Impact</p>
            <p class="font-display text-base text-white leading-snug mb-2">Norm shift on the screen audiences see</p>
            <p class="text-xs text-white/60 leading-relaxed">
              Established RCT evidence (Banerjee &amp; La Ferrara on telenovelas
              shifting fertility / divorce norms; Impact(Ed) <em>My Better
              World</em> shifting girls' school enrolment) shows screen
              content moves measurable behaviour. MAPGEN is the
              measurement-and-targeting infrastructure that work needs.
            </p>
          </div>
        </div>
        <p class="mt-5 text-xs text-white/45 italic max-w-3xl leading-relaxed">
          Each step is independently evidenced — the corpus methodology is
          peer-reviewed; SBCC's behaviour-change effects are RCT-backed.
          MAPGEN connects the measurement step funders and producers
          consistently flag as the missing piece between them.
        </p>
      </div>

      <!-- THE ASK — surfaced near the top so funders don't have to scroll past
           Diverging Mirror, Whitespace, Slate Diagnostic, and CountryPreview
           to find what we want from them. -->
      <div class="mt-10 panel p-6 md:p-8 border border-gold-400/30 bg-gradient-to-b from-gold-400/[0.04] to-transparent">
        <div class="flex flex-wrap items-baseline gap-2">
          <p class="text-xs uppercase tracking-[0.2em] text-gold-400">What V2 unlocks</p>
          <span class="rounded-full bg-emerald-400/10 ring-1 ring-emerald-400/40 text-emerald-300 text-[10px] uppercase tracking-[0.18em] px-2 py-0.5">
            Supported by Gates Foundation
          </span>
        </div>
        <p class="mt-3 font-display text-2xl md:text-3xl text-white leading-tight max-w-3xl">
          From two industries to 160 countries.
        </p>
        <p class="mt-3 text-base text-white/75 leading-relaxed max-w-2xl">
          Today's site reads ~5,400 Bollywood and Hollywood films. With support
          from the <span class="text-white">Gates Foundation</span>, V2 extends
          the same method to ~250,000 films across 160 countries — so
          producers, programmers, and policymakers everywhere can see the same
          kind of mirror we're showing here.
        </p>
        <p class="mt-4 text-sm uppercase tracking-[0.18em] text-white/50">What this opens up</p>
        <ul class="mt-2 space-y-2 text-sm text-white/75 leading-relaxed">
          <li><span class="text-white">·</span> <span class="text-white">Country-level diagnostics</span> — see how a national cinema's gendered patterns shift over time</li>
          <li><span class="text-white">·</span> <span class="text-white">Cross-cultural comparison</span> — measure where industries converge and diverge on shame and pride</li>
          <li><span class="text-white">·</span> <span class="text-white">Slate-level reads</span> — explore the norm profile of a production slate against the broader corpus</li>
          <li><span class="text-white">·</span> <span class="text-white">Longitudinal research</span> — a comparable evidence base across countries, languages, and decades</li>
        </ul>

        <!-- V2 timeline — funders consistently ask "when does this actually deliver" -->
        <div class="mt-5 grid gap-3 sm:grid-cols-3 max-w-2xl">
          <div class="rounded-lg bg-ink-950/40 ring-1 ring-white/5 px-3 py-2.5">
            <p class="text-[10px] uppercase tracking-[0.18em] text-emerald-300/80">Live now (V1)</p>
            <p class="mt-1 text-sm text-white">Bollywood + Hollywood</p>
            <p class="text-[11px] text-white/50">~5,400 films · this site</p>
          </div>
          <div class="rounded-lg bg-ink-950/40 ring-1 ring-white/5 px-3 py-2.5">
            <p class="text-[10px] uppercase tracking-[0.18em] text-amber-300/80">Alpha · this year</p>
            <p class="mt-1 text-sm text-white">+ 4 pilot industries</p>
            <p class="text-[11px] text-white/50">Korea, France, Nigeria, S. India</p>
          </div>
          <div class="rounded-lg bg-ink-950/40 ring-1 ring-white/5 px-3 py-2.5">
            <p class="text-[10px] uppercase tracking-[0.18em] text-white/55">V2 · 36-month build</p>
            <p class="mt-1 text-sm text-white">160 countries</p>
            <p class="text-[11px] text-white/50">~250,000 films, public dashboard</p>
          </div>
        </div>
        <div class="mt-5 flex flex-wrap gap-3">
          <a href="#feedback-anchor"
             class="inline-flex items-center gap-2 rounded-full bg-gold-400 text-ink-950 px-5 py-2.5 text-sm font-medium hover:bg-gold-300 transition">
            Tell us what would be useful →
          </a>
          <button type="button"
                  data-mu="c2hhcmF0aGc=" data-md="Y2lzLnVwZW5uLmVkdQ=="
                  data-ms="MAPGEN V2"
                  class="inline-flex items-center gap-2 rounded-full bg-white/5 ring-1 ring-white/10 text-white/80 px-5 py-2.5 text-sm hover:bg-white/10 hover:text-white transition">
            Email the project lead
          </button>
        </div>
      </div>

      <div class="mt-12">
        <DivergingMirror client:load trend={mirror.era_trend} />
      </div>

      <!-- Audience-signal callout — for studio / streamer readers who need
           to see this trend as a market signal, not a moral one. Anchored
           on the established Annenberg Inclusion Initiative finding that
           inclusive films perform commercially when distributed widely. -->
      <div class="mt-6 panel p-5 md:p-6 border-l-2 border-holly bg-holly/[0.04]">
        <p class="text-xs uppercase tracking-[0.2em] text-holly mb-2">Why this is a market signal, not just a moral one</p>
        <p class="text-sm md:text-base text-white/80 leading-relaxed max-w-3xl">
          The Annenberg Inclusion Initiative's annual box-office analyses
          (USC) show that films passing the Bechdel–Wallace threshold and
          films with women in lead roles
          <span class="text-white">consistently match or out-perform comparable
          non-inclusive titles at the box office</span>, when distributed at
          comparable scale. The audience movement above isn't a preference
          shift you need to chase — it's a preference shift that already
          rewards the slates that move with it.
        </p>
        <p class="mt-3 text-xs text-white/45 italic">
          See Annenberg's annual <em>Inclusion in the Director's Chair</em>
          and <em>Inequality in Popular Films</em> reports for the
          underlying ROI analysis.
        </p>
      </div>

      <div class="mt-10">
        <WhitespaceMap client:load items={studio.whitespace} />
      </div>

      <!-- NEW: Slate Diagnostic -->
      <div class="mt-10">
        <SlateDiagnostic client:load films={atlas.films_index} />
      </div>

      <!-- NEW: Country Preview -->
      <div class="mt-10">
        <CountryPreview client:load />
      </div>

      <!-- Funder's Slate Audit Checklist — parallel to Writers' Room -->
      <div class="mt-10">
        <FundersChecklist />
      </div>

    </div>

    <!-- =========================================================== -->
    <!-- §3 — PROGRAMMERS / POLICY / EDUCATORS                        -->
    <!-- =========================================================== -->
    <div id="programmers" class="mt-32 scroll-mt-24">
      <div class="border-l-2 border-holly pl-6">
        <p class="text-xs uppercase tracking-[0.25em] text-holly">Dossier 03 · Programmers, policymakers, educators</p>
        <h2 class="mt-2 font-display text-4xl md:text-5xl text-white max-w-3xl leading-tight">
          What does our cinema say about us?
        </h2>
        <p class="mt-4 max-w-2xl text-base text-white/70 leading-relaxed">
          Below the languages, the genres, the soundtracks — there are gender
          norms that hold across both industries. The convergence zone is where
          the cross-cultural conversation begins.
        </p>
      </div>

      <!-- How to read this — descriptive framing for the policy/programmer audience. -->
      <div class="mt-8 max-w-2xl text-xs text-white/55 italic leading-relaxed border-l-2 border-holly/30 pl-4">
        How to read this: the convergence below names patterns that hold
        across both industries. Naming a pattern is not the same as
        endorsing it. Use the data to start a conversation in your
        programming, panels, or syllabi about which shared expectations
        the screen reinforces — and whose work breaks them.
      </div>

      <div class="mt-12">
        <ConvergenceZone client:load items={studio.convergence} />
      </div>

      <div class="mt-10">
        <DiscussionKit />
      </div>

      <!-- Policy Levers — for actual policymakers (parliamentary staff,
           ministry officials, multilateral programme officers, broadcasting
           authorities). Maps the corpus's findings to four classes of policy
           tool that countries already use to shape screen content. -->
      <div class="mt-10 panel p-6 md:p-10">
        <p class="text-xs uppercase tracking-[0.25em] text-gold-400">Policy levers</p>
        <h3 class="mt-1 font-display text-2xl text-white max-w-3xl">
          Four classes of policy tool that already shape screen content — and where this evidence base plugs in.
        </h3>
        <p class="mt-3 max-w-2xl text-sm text-white/60">
          The corpus is descriptive; the levers below are not. Each names a
          policy mechanism countries already use to influence the gendered
          content of their cinema, with examples and where MAPGEN-style
          evidence informs the design or evaluation step.
        </p>

        <div class="mt-6 grid gap-4 md:grid-cols-2">
          <!-- Lever 1: Public investment / co-production funds -->
          <div class="rounded-xl bg-ink-950/40 ring-1 ring-white/5 p-5">
            <p class="text-[10px] uppercase tracking-[0.2em] text-holly/80 mb-2">1 · Public investment</p>
            <p class="font-display text-base text-white leading-snug">Conditioning film funding on inclusion criteria.</p>
            <p class="mt-2 text-xs text-white/65 leading-relaxed">
              <span class="text-white">Examples in practice:</span> BFI Diversity
              Standards qualify projects for UK public film funding; Eurimages
              awards a gender-equality bonus when women fill 5 of 8 key
              creative roles; Telefilm Canada parity targets.
            </p>
            <p class="mt-2 text-xs text-white/45 leading-relaxed">
              <span class="text-white/65">Where MAPGEN plugs in:</span>
              measuring whether funded projects deliver on the <em>on-screen</em>
              gender-norm criteria the funding instrument promised — not just
              the credits-line representation that's easier to count.
            </p>
          </div>

          <!-- Lever 2: Tax credits / fiscal incentives -->
          <div class="rounded-xl bg-ink-950/40 ring-1 ring-white/5 p-5">
            <p class="text-[10px] uppercase tracking-[0.2em] text-holly/80 mb-2">2 · Fiscal incentives</p>
            <p class="font-display text-base text-white leading-snug">Tax credits and rebates tied to inclusion thresholds.</p>
            <p class="mt-2 text-xs text-white/65 leading-relaxed">
              <span class="text-white">Examples in practice:</span> Ireland's
              Section 481 (uplift for regional and gender-balanced productions);
              the UK's Audio-Visual Expenditure Credit; California's CFC tax
              credit's diversity uplift.
            </p>
            <p class="mt-2 text-xs text-white/45 leading-relaxed">
              <span class="text-white/65">Where MAPGEN plugs in:</span>
              providing a content-level audit standard that revenue
              authorities can use to verify diversity uplift claims at scale.
            </p>
          </div>

          <!-- Lever 3: Broadcasting / platform regulation -->
          <div class="rounded-xl bg-ink-950/40 ring-1 ring-white/5 p-5">
            <p class="text-[10px] uppercase tracking-[0.2em] text-holly/80 mb-2">3 · Broadcasting &amp; platform regulation</p>
            <p class="font-display text-base text-white leading-snug">Public-service obligations and content quotas on broadcasters and streamers.</p>
            <p class="mt-2 text-xs text-white/65 leading-relaxed">
              <span class="text-white">Examples in practice:</span> EU Audiovisual
              Media Services Directive (30% European-works quota on streamers);
              India's Cinematograph Act content classification; UK Ofcom's
              public-service-broadcasting reviews.
            </p>
            <p class="mt-2 text-xs text-white/45 leading-relaxed">
              <span class="text-white/65">Where MAPGEN plugs in:</span>
              independent measurement infrastructure for regulators
              evaluating platform compliance with on-screen norm-related
              public-interest obligations.
            </p>
          </div>

          <!-- Lever 4: SBCC / edutainment public investment -->
          <div class="rounded-xl bg-ink-950/40 ring-1 ring-white/5 p-5">
            <p class="text-[10px] uppercase tracking-[0.2em] text-holly/80 mb-2">4 · SBCC &amp; edutainment investment</p>
            <p class="font-display text-base text-white leading-snug">Public investment in entertainment-education programming.</p>
            <p class="mt-2 text-xs text-white/65 leading-relaxed">
              <span class="text-white">Examples in practice:</span> Nigeria's
              MBW radio drama; Population Media Center's serial drama
              programming in 50+ countries; Sesame Workshop's localized
              early-childhood content; World Bank DIME's edutainment RCTs.
            </p>
            <p class="mt-2 text-xs text-white/45 leading-relaxed">
              <span class="text-white/65">Where MAPGEN plugs in:</span>
              formative input for script-stage cultural calibration and
              endline measurement of whether the produced content delivers
              on the norm targets the campaign was funded against.
            </p>
          </div>
        </div>

        <p class="mt-6 text-xs text-white/45 italic max-w-3xl leading-relaxed">
          Aligned with <span class="text-white/60">UN 2.0 Quintet of Change</span>
          (data, innovation, digital, foresight, behavioural science) and
          <span class="text-white/60">SDG 5</span> (gender equality) targets
          5.1, 5.5, and 5.c. The corpus is open-licensed (CC-BY-SA) so
          national policy researchers can audit, replicate, or extend the
          methodology in their own jurisdictions.
        </p>
      </div>

      <!-- Programmer's Curation Checklist — parallel to Writers' Room -->
      <div class="mt-10">
        <ProgrammersChecklist />
      </div>

      <div class="mt-10 panel p-6 md:p-8 border-l-2 border-holly">
        <p class="text-xs uppercase tracking-[0.2em] text-holly mb-2">What to do next</p>
        <p class="text-base text-white/80 leading-relaxed">
          Use the framework in your programming, your panels, your syllabi.
          The dataset is{" "}
          <a href="https://github.com/Khushangz/Cross-Cultural-Social-Norms-Dataset"
             target="_blank" rel="noopener" class="text-gold-400 hover:underline">
            CC-BY-SA on GitHub →
          </a>
          {" "}and the paper is{" "}
          <a href={base + "/paper.pdf"} target="_blank" rel="noopener"
             class="text-gold-400 hover:underline">
            Rai et al., NAACL 2025 →
          </a>
        </p>
      </div>
    </div>

    <!-- =========================================================== -->
    <!-- Closing — back to feedback                                    -->
    <!-- =========================================================== -->
    <div id="feedback-anchor" class="mt-32 panel p-8 md:p-12 text-center border border-gold-400/20 bg-gradient-to-b from-gold-400/[0.04] to-transparent">
      <p class="text-xs uppercase tracking-[0.25em] text-gold-400">Help shape what's next</p>
      <h3 class="mt-3 font-display text-3xl text-white max-w-2xl mx-auto leading-tight">
