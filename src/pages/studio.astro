---
import Layout from "../layouts/Layout.astro";
import NormCompass from "../components/Studio/NormCompass.tsx";
import DivergingMirror from "../components/Studio/DivergingMirror.tsx";
import ConvergenceZone from "../components/Studio/ConvergenceZone.tsx";
import WhitespaceMap from "../components/Studio/WhitespaceMap.tsx";
import SubversionFiles from "../components/Studio/SubversionFiles.tsx";
import SlateDiagnostic from "../components/Studio/SlateDiagnostic.tsx";
import CountryPreview from "../components/Studio/CountryPreview.tsx";
import WritersChecklist from "../components/Studio/WritersChecklist.astro";
import DiscussionKit from "../components/Studio/DiscussionKit.astro";

const studio = (await import("../../public/data/station4_studio.json", { assert: { type: "json" } })).default;
const mirror = (await import("../../public/data/station1_mirror.json", { assert: { type: "json" } })).default;
const atlas = (await import("../../public/data/station2_atlas.json", { assert: { type: "json" } })).default;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout title="The Studio — MAPGEN: Cinema's Mirror" station="studio">
  <section class="container-kiosk pt-16 pb-32">
    <p class="text-xs uppercase tracking-[0.3em] text-gold-400">Station 4</p>
    <h1 class="mt-3 font-display text-kiosk-xl text-white max-w-3xl">The Studio.</h1>
    <p class="mt-4 max-w-2xl text-kiosk-md text-white/75 leading-snug">
      Three audiences. One mirror. Different asks. This is what MAPGEN unlocks
      for filmmakers, funders, and the people who program, study, and govern cinema.
    </p>

    <!-- Jump-to nav -->
    <div class="mt-10 flex flex-wrap gap-2 text-xs">
      <a href="#filmmakers" class="rounded-full bg-bolly/10 ring-1 ring-bolly/30 px-3 py-2 text-bolly hover:bg-bolly/20 transition min-h-[40px] inline-flex items-center">
        ↓ For filmmakers
      </a>
      <a href="#funders" class="rounded-full bg-gold-400/10 ring-1 ring-gold-400/30 px-3 py-2 text-gold-400 hover:bg-gold-400/20 transition min-h-[40px] inline-flex items-center">
        ↓ For funders &amp; studios
      </a>
      <a href="#programmers" class="rounded-full bg-holly/10 ring-1 ring-holly/30 px-3 py-2 text-holly hover:bg-holly/20 transition min-h-[40px] inline-flex items-center">
        ↓ For policy &amp; educators
      </a>
      <a href={base + "/about"} class="rounded-full bg-white/5 ring-1 ring-white/15 px-3 py-2 text-white/70 hover:bg-white/10 hover:text-white transition min-h-[40px] inline-flex items-center">
        Method &amp; citations →
      </a>
    </div>

    <!-- =========================================================== -->
    <!-- §1 — FILMMAKERS                                              -->
    <!-- =========================================================== -->
    <div id="filmmakers" class="mt-28 scroll-mt-24">
      <div class="border-l-2 border-bolly pl-6">
        <p class="text-xs uppercase tracking-[0.25em] text-bolly">Dossier 01 · Filmmakers</p>
        <h2 class="mt-2 font-display text-4xl md:text-5xl text-white max-w-3xl leading-tight">
          Explore your dialogue for markers of shame and pride.
        </h2>
        <p class="mt-4 max-w-2xl text-base text-white/70 leading-relaxed">
          Every scene carries signals of the social norms it invokes — who is
          shamed, who is celebrated, and for what. MAPGEN surfaces
          <span class="text-white font-medium"> 12,387 such moments</span> across
          film dialogue, giving you a way to read your own scene against patterns
          the corpus has already mapped.
        </p>
      </div>

      <div class="mt-12">
        <NormCompass client:load archetypes={studio.compass} />
      </div>

      <div class="mt-10">
        <SubversionFiles client:load items={studio.subversions} />
      </div>

      <div class="mt-10">
        <WritersChecklist />
      </div>

      <div class="mt-10 panel p-6 md:p-8 border-l-2 border-bolly">
        <p class="text-xs uppercase tracking-[0.2em] text-bolly mb-2">What to do next</p>
        <p class="text-base text-white/80 leading-relaxed">
          Take a scene from your current project. Paste it into{" "}
          <a href={base + "/lens#paste-scene"} class="text-gold-400 hover:underline">The Lens</a> —
          we'll read it through both cultural lenses and surface what an Indian
          audience might register that an American one would miss, and vice versa.
        </p>
      </div>
    </div>

    <!-- =========================================================== -->
    <!-- §2 — FUNDERS                                                 -->
    <!-- =========================================================== -->
    <div id="funders" class="mt-32 scroll-mt-24">
      <div class="border-l-2 border-gold-400 pl-6">
        <p class="text-xs uppercase tracking-[0.25em] text-gold-400">Dossier 02 · Funders &amp; studios</p>
        <h2 class="mt-2 font-display text-4xl md:text-5xl text-white max-w-3xl leading-tight">
          What's the gender norm profile of your slate — and where's your audience moving?
        </h2>
        <p class="mt-4 max-w-2xl text-base text-white/70 leading-relaxed">
          Gender representation isn't a moral metric. It's a market signal. The
          two industries have started moving in opposite directions on the same
          measure since 2000 — and the audience has shown which way it's leaning.
        </p>
      </div>

      <!-- THE ASK — surfaced near the top so funders don't have to scroll past
           Diverging Mirror, Whitespace, Slate Diagnostic, and CountryPreview
           to find what we want from them. -->
      <div class="mt-10 panel p-6 md:p-8 border border-gold-400/30 bg-gradient-to-b from-gold-400/[0.04] to-transparent">
        <div class="flex flex-wrap items-baseline gap-2">
          <p class="text-xs uppercase tracking-[0.2em] text-gold-400">What V2 unlocks</p>
          <span class="rounded-full bg-emerald-400/10 ring-1 ring-emerald-400/40 text-emerald-300 text-[10px] uppercase tracking-[0.18em] px-2 py-0.5">
            Supported by Gates Foundation
          </span>
        </div>
        <p class="mt-3 font-display text-2xl md:text-3xl text-white leading-tight max-w-3xl">
          From two industries to 160 countries.
        </p>
        <p class="mt-3 text-base text-white/75 leading-relaxed max-w-2xl">
          Today's site reads ~5,400 Bollywood and Hollywood films. With support
          from the <span class="text-white">Gates Foundation</span>, V2 extends
          the same method to ~250,000 films across 160 countries — so
          producers, programmers, and policymakers everywhere can see the same
          kind of mirror we're showing here.
        </p>
        <p class="mt-4 text-sm uppercase tracking-[0.18em] text-white/50">What this opens up</p>
        <ul class="mt-2 space-y-2 text-sm text-white/75 leading-relaxed">
          <li><span class="text-white">·</span> <span class="text-white">Country-level diagnostics</span> — see how a national cinema's gendered patterns shift over time</li>
          <li><span class="text-white">·</span> <span class="text-white">Cross-cultural comparison</span> — measure where industries converge and diverge on shame and pride</li>
          <li><span class="text-white">·</span> <span class="text-white">Slate-level reads</span> — explore the norm profile of a production slate against the broader corpus</li>
          <li><span class="text-white">·</span> <span class="text-white">Longitudinal research</span> — a comparable evidence base across countries, languages, and decades</li>
        </ul>
        <div class="mt-5 flex flex-wrap gap-3">
          <a href="#feedback-anchor"
             class="inline-flex items-center gap-2 rounded-full bg-gold-400 text-ink-950 px-5 py-2.5 text-sm font-medium hover:bg-gold-300 transition">
            Tell us what would be useful →
          </a>
          <button type="button"
                  data-mu="c2hhcmF0aGc=" data-md="Y2lzLnVwZW5uLmVkdQ=="
                  data-ms="MAPGEN V2"
                  class="inline-flex items-center gap-2 rounded-full bg-white/5 ring-1 ring-white/10 text-white/80 px-5 py-2.5 text-sm hover:bg-white/10 hover:text-white transition">
            Email the project lead
          </button>
        </div>
      </div>

      <div class="mt-12">
        <DivergingMirror client:load trend={mirror.era_trend} />
      </div>

      <div class="mt-10">
        <WhitespaceMap client:load items={studio.whitespace} />
      </div>

      <!-- NEW: Slate Diagnostic -->
      <div class="mt-10">
        <SlateDiagnostic client:load films={atlas.films_index} />
      </div>

      <!-- NEW: Country Preview -->
      <div class="mt-10">
        <CountryPreview client:load />
      </div>

    </div>

    <!-- =========================================================== -->
    <!-- §3 — PROGRAMMERS / POLICY / EDUCATORS                        -->
    <!-- =========================================================== -->
    <div id="programmers" class="mt-32 scroll-mt-24">
      <div class="border-l-2 border-holly pl-6">
        <p class="text-xs uppercase tracking-[0.25em] text-holly">Dossier 03 · Programmers, policymakers, educators</p>
        <h2 class="mt-2 font-display text-4xl md:text-5xl text-white max-w-3xl leading-tight">
          What does our cinema say about us?
        </h2>
        <p class="mt-4 max-w-2xl text-base text-white/70 leading-relaxed">
          Below the languages, the genres, the soundtracks — there are gender
          norms that hold across both industries. The convergence zone is where
          the cross-cultural conversation begins.
        </p>
      </div>

      <div class="mt-12">
        <ConvergenceZone client:load items={studio.convergence} />
      </div>

      <div class="mt-10">
        <DiscussionKit />
      </div>

      <div class="mt-10 panel p-6 md:p-8 border-l-2 border-holly">
        <p class="text-xs uppercase tracking-[0.2em] text-holly mb-2">What to do next</p>
        <p class="text-base text-white/80 leading-relaxed">
          Use the framework in your programming, your panels, your syllabi.
          The dataset is{" "}
          <a href="https://github.com/Khushangz/Cross-Cultural-Social-Norms-Dataset"
             target="_blank" rel="noopener" class="text-gold-400 hover:underline">
            CC-BY-SA on GitHub →
          </a>
          {" "}and the paper is{" "}
          <a href={base + "/paper.pdf"} target="_blank" rel="noopener"
             class="text-gold-400 hover:underline">
            Rai et al., NAACL 2025 →
          </a>
        </p>
      </div>
    </div>

    <!-- =========================================================== -->
    <!-- Closing — back to feedback                                    -->
    <!-- =========================================================== -->
    <div id="feedback-anchor" class="mt-32 panel p-8 md:p-12 text-center border border-gold-400/20 bg-gradient-to-b from-gold-400/[0.04] to-transparent">
      <p class="text-xs uppercase tracking-[0.25em] text-gold-400">Help shape what's next</p>
      <h3 class="mt-3 font-display text-3xl text-white max-w-2xl mx-auto leading-tight">
        What cuts of this data would be most useful in your work?
      </h3>
      <p class="mt-4 max-w-2xl mx-auto text-sm text-white/65 leading-relaxed">
        We're shaping V2. The most useful input we can get right now is which
        comparisons, which views, and which exports would actually inform a
        decision in your field.
      </p>
      <a href={base + "/#feedback"}
         class="mt-6 inline-flex items-center gap-2 rounded-full bg-gold-400 text-ink-950 px-5 py-2.5 text-sm font-medium hover:bg-gold-300 transition">
        Share your input →
      </a>
    </div>
  </section>
</Layout>
