# Copy this to .env.local and fill in real values. .env.local is gitignored.

# TMDB — used for poster, plot, year, country, cast enrichment
TMDB_API_KEY=
TMDB_READ_TOKEN=

# OpenAI / model used by the Mode A live LLM endpoint (Station 3)
# Set on the Vercel/Cloudflare deployment, not committed.
OPENAI_API_KEY=
LLM_MODEL=gpt-5.5

# Privacy-friendly, cookieless analytics. Always-on pageview tracking — no
# cookies, no consent banner, no custom events. Pick ONE provider. Leave all
# blank to disable (nothing renders). Must be set at BUILD time (baked into
# the static HTML), so set it in the deploy/build env too.
#   Cloudflare Web Analytics (free, unlimited — recommended): token from
#   the Cloudflare dashboard (Web Analytics → add the site → JS snippet token)
PUBLIC_ANALYTICS_CF_TOKEN=
#   Plausible (cloud is paid; self-host free): the data-domain (bare host)
PUBLIC_ANALYTICS_DOMAIN=
#   Optional: override the script URL (self-hosted Plausible / Umami script)
PUBLIC_ANALYTICS_SRC=
#   Umami (free hobby tier): website id, plus PUBLIC_ANALYTICS_SRC
PUBLIC_ANALYTICS_WEBSITE_ID=
