# Copy this to .env.local and fill in real values. .env.local is gitignored.

# TMDB — used for poster, plot, year, country, cast enrichment
TMDB_API_KEY=
TMDB_READ_TOKEN=

# OpenAI / model used by the Mode A live LLM endpoint (Station 3)
# Set on the Vercel/Cloudflare deployment, not committed.
OPENAI_API_KEY=
LLM_MODEL=gpt-5.5

# Privacy-friendly, cookieless analytics (Plausible by default). Always-on
# pageview tracking — no cookies, no consent banner, no custom events.
# Leave blank to disable (the tag won't render). Must be set at BUILD time
# (it's baked into the static HTML), so set it in the deploy/build env too.
#   Plausible: the data-domain — the bare host the site is served from
PUBLIC_ANALYTICS_DOMAIN=
#   Optional: override the script URL (self-hosted Plausible, etc.)
PUBLIC_ANALYTICS_SRC=
#   Umami alternative: set this instead of PUBLIC_ANALYTICS_DOMAIN (+ _SRC)
PUBLIC_ANALYTICS_WEBSITE_ID=
